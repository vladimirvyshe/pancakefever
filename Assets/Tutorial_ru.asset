  m_TableData:
  - m_Id: 6288683008
    m_Localized: "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C
      \u043D\u0430 \u043A\u0443\u0445\u043D\u044E!\\n\u0421\u0435\u0439\u0447\u0430\u0441
      \u0431\u044B\u0441\u0442\u0440\u043E \u043D\u0430\u0443\u0447\u0443 \u0442\u0435\u0431\u044F
      \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0442\u044C \u0437\u0430\u043A\u0430\u0437\u044B.\\n\\n\u041D\u0430\u0436\u043C\u0438
      \xAB\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C\xBB, \u043A\u043E\u0433\u0434\u0430
      \u0431\u0443\u0434\u0435\u0448\u044C \u0433\u043E\u0442\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 49850724352
    m_Localized: "\u0428\u0430\u0433 1/3\\n\u041D\u0430\u0436\u043C\u0438 \xAB\u0417\u0430\u043B\u0438\u0442\u044C
      \u0442\u0435\u0441\u0442\u043E\xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 91202367488
    m_Localized: "\u0428\u0430\u0433 2/3\\n\u041F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0438
      \u0432\u043E\u0432\u0440\u0435\u043C\u044F \u2014 \u0431\u043B\u0438\u043D
      \u043C\u043E\u0436\u0435\u0442 \u0441\u0433\u043E\u0440\u0435\u0442\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 148219736064
    m_Localized: "\u0428\u0430\u0433 3/3\\n\u0422\u0435\u043F\u0435\u0440\u044C \u0443\u043F\u0430\u043A\u0443\u0439
      \u0437\u0430\u043A\u0430\u0437."
    m_Metadata:
      m_Items: []
  - m_Id: 205530705920
    m_Localized: "\u0421\u0434\u0435\u043B\u0430\u0439 \u0435\u0449\u0451 \u043F\u0430\u0440\u0443
      \u0437\u0430\u043A\u0430\u0437\u043E\u0432,\\n\u0447\u0442\u043E\u0431\u044B
      \u043D\u0430\u043A\u043E\u043F\u0438\u0442\u044C {0} \u043C\u043E\u043D\u0435\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 280323534848
    m_Localized: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E!\\n\u041E\u0442\u043A\u0440\u043E\u0439
      \u043C\u0430\u0433\u0430\u0437\u0438\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 312611287040
    m_Localized: "\u041A\u0443\u043F\u0438 \u0434\u0436\u0435\u043C, \u0447\u0442\u043E\u0431\u044B
      \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u0442\u044C \u043D\u0430\u0447\u0438\u043D\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 376259850240
    m_Localized: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E!\\n\u0422\u0435\u043F\u0435\u0440\u044C
      \u0437\u0430\u043A\u0440\u043E\u0439 \u043C\u0430\u0433\u0430\u0437\u0438\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 409210302464
    m_Localized: "\u041A\u043E\u0433\u0434\u0430 \u043F\u0440\u0438\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u0441\u044F
      \u0431\u043B\u0438\u043D:\\n1) \u041D\u0430\u0436\u043C\u0438 \u043D\u0430
      \u0434\u0436\u0435\u043C \u0432\u043D\u0438\u0437\u0443\\n2) \u0422\u0430\u043F\u043D\u0438
      \u043F\u043E \u0431\u043B\u0438\u043D\u0443, \u0447\u0442\u043E\u0431\u044B
      \u043D\u0430\u043D\u0435\u0441\u0442\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 485223673856
    m_Localized: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E!\\n\u041D\u0430\u0447\u0438\u043D\u043A\u0430
      \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0432\u0430\u0435\u0442 \u043D\u0430\u0433\u0440\u0430\u0434\u0443\\n\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0439
      \u0438\u0433\u0440\u0430\u0442\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 3705035665408
    m_Localized: "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C"
    m_Metadata:
      m_Items: []
