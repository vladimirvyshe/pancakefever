    m_Items: []
  m_TableData:
  - m_Id: 6288683008
    m_Localized: "Welcome to the kitchen!\\nI'll quickly teach you how to complete
      orders.\\n\\nTap \u201CContinue\u201D when you\u2019re ready."
    m_Metadata:
      m_Items: []
  - m_Id: 49850724352
    m_Localized: "Step 1/3\\nTap \u201CPour batter\u201D."
    m_Metadata:
      m_Items: []
  - m_Id: 91202367488
    m_Localized: "Step 2/3\\nFlip in time \u2014 the pancake can burn!"
    m_Metadata:
      m_Items: []
  - m_Id: 148219736064
    m_Localized: Step 3/3\nNow pack the order.
    m_Metadata:
      m_Items: []
  - m_Id: 205530705920
    m_Localized: Complete a few more orders\nto save up {0} coins
    m_Metadata:
      m_Items: []
  - m_Id: 280323534848
    m_Localized: Nice!\nOpen the shop.
    m_Metadata:
      m_Items: []
  - m_Id: 312611287040
    m_Localized: Buy jam to add toppings.
    m_Metadata:
      m_Items: []
  - m_Id: 376259850240
    m_Localized: Great!\nNow close the shop.
    m_Metadata:
      m_Items: []
  - m_Id: 409210302464
    m_Localized: When the pancake is ready:\n1) Tap jam at the bottom\n2) Tap the
      pancake to apply it
    m_Metadata:
      m_Items: []
  - m_Id: 485223673856
    m_Localized: Great!\nToppings increase your reward.\nKeep playing!
    m_Metadata:
      m_Items: []
  - m_Id: 3705035665408
    m_Localized: "\u0421ontinue"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
